FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc libpango-1.0-0 libpangocairo-1.0-0 \
    libgdk-pixbuf-2.0-0 libffi-dev shared-mime-info \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    fastapi "uvicorn[standard]" sqlalchemy psycopg2-binary \
    redis boto3 pydantic pydantic-settings stripe \
    "python-jose[cryptography]" "passlib[bcrypt]" "bcrypt<4.1" \
    python-multipart httpx alembic \
    jinja2 weasyprint pyyaml anthropic "elasticsearch>=8.13,<9" \
    pyotp "qrcode[pil]" \
    python-socketio python-socketio-client aiofiles

COPY modules/ /app/modules/
COPY config/ /app/config/
WORKDIR /app

ENV RUNTIME=local
ENV PYTHONUNBUFFERED=1
EXPOSE 8000

CMD ["uvicorn", "modules.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
