    "default_format": "html",
    "formats": ["pdf", "html", "json"],
    "html_template": "templates/html_template.html",
    "pdf_template": "templates/pdf_template.html"
  },
  "monitoring": {
    "health_check_interval": 60,
    "alert_threshold": 70
  },
  "api": {
    "base_url": "https://api.securityscanner.com",
    "cors_origins": ["https://securityscanner.com", "http://localhost:3000"]
  }
