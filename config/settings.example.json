{
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "security_scanner",
    "user": "scanner_user",
    "password": "<YOUR_DB_PASSWORD>"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "password": null
  },
  "email": {
    "smtp_host": "smtp.example.com",
    "smtp_port": 587,
    "smtp_user": "<YOUR_SMTP_USER>",
    "smtp_password": "<YOUR_SMTP_PASSWORD>",
    "from_email": "security@example.com",
    "from_name": "Security Scanner"
  },
  "payment": {
    "stripe_api_key": "<YOUR_STRIPE_KEY>",
    "stripe_webhook_secret": "<YOUR_STRIPE_WEBHOOK_SECRET>",
    "paypal_client_id": "<YOUR_PAYPAL_CLIENT_ID>",
    "paypal_secret": "<YOUR_PAYPAL_SECRET>"
  },
  "flowhunt": {
    "api_key": "<YOUR_FLOWHUNT_API_KEY>",
    "flow_id": "<YOUR_FLOWHUNT_FLOW_ID>",
    "api_url": "https://api.flowhunt.ai"
  },
  "scan_config": {
    "external_timeout": 1800,
    "internal_timeout": 3600,
    "max_concurrent_scans": 3,
    "priority_queue_size": 10
  },
  "reporting": {
    "default_format": "html",
    "formats": ["pdf", "html", "json"],
    "html_template": "templates/html_template.html",
    "pdf_template": "templates/pdf_template.html"
  },
  "monitoring": {
    "health_check_interval": 60,
    "alert_threshold": 70
  },
  "api": {
    "base_url": "https://api.securityscanner.com",
    "cors_origins": ["https://securityscanner.com", "http://localhost:3000"]
  }
}
