# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional — defaults work for local dev
JWT_SECRET=dev-secret-change-in-production
DATABASE_URL=postgresql://scanner:scanner@postgres:5432/scanner
REDIS_URL=redis://redis:6379

# Notifications (JSON array of channel configs)
# Example: [{"type":"slack","config":{"webhook_url":"https://hooks.slack.com/..."},"min_severity":"warning"}]
NOTIFICATION_CHANNELS=[]

# OpenClaw integration (optional)
OPENCLAW_GATEWAY_URL=http://localhost:3080
OPENCLAW_API_KEY=

# NemoClaw/OpenShell (optional — for sandboxed agent execution)
OPENSHELL_ENABLED=false
NEMOCLAW_INFERENCE_PROVIDER=anthropic
