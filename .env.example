# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI Model — choose which Claude model to use for scans and chat
# Options: claude-haiku-4-5-20251001 (cheap), claude-sonnet-4-20250514 (balanced), claude-opus-4-20250514 (best)
AI_MODEL=claude-haiku-4-5-20251001
AI_MODEL_LIGHT=claude-haiku-4-5-20251001

# Heartbeat — platform health check interval in seconds
HEARTBEAT_INTERVAL=120

# Optional — defaults work for local dev
JWT_SECRET=dev-secret-change-in-production
DATABASE_URL=postgresql://scanner:scanner@postgres:5432/scanner
REDIS_URL=redis://redis:6379

# Notifications (JSON array of channel configs)
# Example: [{"type":"slack","config":{"webhook_url":"https://hooks.slack.com/..."},"min_severity":"warning"}]
NOTIFICATION_CHANNELS=[]

# OpenClaw integration (optional)
OPENCLAW_GATEWAY_URL=http://localhost:3080
OPENCLAW_API_KEY=

# NemoClaw/OpenShell (optional — for sandboxed agent execution)
OPENSHELL_ENABLED=false
NEMOCLAW_INFERENCE_PROVIDER=anthropic
